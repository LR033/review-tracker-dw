# Copy this file to `.streamlit/secrets.toml` and fill in your keys.
# secrets.toml is gitignored so the keys never get committed.
#
# ANTHROPIC_API_KEY — used by dashboard/app.py for the "Draft reply with Claude"
# and "Analyze" features. Without it the dashboard still runs; only the
# Claude-powered features are disabled.
ANTHROPIC_API_KEY = "sk-ant-..."

# TOURDASH_API_KEY — TourDash booking API key. The scraper
# (scrapers/tourdash_scraper.py) reads it from the environment; keep a copy
# here so the dashboard environment also carries it. Mirror it as a GitHub
# Actions secret named TOURDASH_API_KEY so the daily scrape can pull bookings.
TOURDASH_API_KEY = "td_..."
